# Generated by Cargo
# will have compiled files and executables
/target/
/gen/schemas

# Brein sidecar (built by PyInstaller, bundled as a Tauri resource — never committed)
/binaries/

# Per-client seed payloads (white-label) — never committed
/seed/*.json

# Updater signing keys — the PRIVATE key must never be committed.
# Only the .pub is safe; the matching public key is embedded in tauri.conf.json
# and the private key + password are CI secrets (TAURI_SIGNING_PRIVATE_KEY*).
/.tauri/
