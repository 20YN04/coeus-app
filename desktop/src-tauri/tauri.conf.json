{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Coeus",
  "version": "0.3.0",
  "identifier": "app.coeus.kennisbank",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: http://asset.localhost; font-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src 'self' http://127.0.0.1:8765 ipc: http://ipc.localhost; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; form-action 'self'"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDMxRjQwNjVCRjUxNTk1REIKUldUYmxSWDFXd2IwTVNoMW0rOFp4R0RQZjEwREtYZHpaeHpwejlwckYva1c0UUgwOUxxYkJWbGsK",
      "endpoints": [
        "https://github.com/20YN04/coeus-app/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "binaries/coeus-brein/**/*",
      "seed/*"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
