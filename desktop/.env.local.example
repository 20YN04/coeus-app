# Per-client build config — baked into the static export at build time.
NEXT_PUBLIC_TENANT_NAME="Uw Bedrijf"
NEXT_PUBLIC_TENANT_SLUG="uwbedrijf"
NEXT_PUBLIC_TENANT_LOGO="/logo.svg"
NEXT_PUBLIC_TENANT_ACCENT="#C2410C"

# Local brein sidecar (loopback). The Tauri shell launches the brein here.
NEXT_PUBLIC_BREIN_URL="http://127.0.0.1:8765"

# Login-gate (feat/app-login-gate). Absent/"false" = no gate, exact current
# behaviour — required for the public build. Only "true" activates it.
# NEXT_PUBLIC_AUTH_REQUIRED="true"
# coeus-auth base URL. Defaults to the production service; point at your
# local `uvicorn app.main:app --port 8790` for dev/e2e testing.
# NEXT_PUBLIC_AUTH_URL="https://auth.coeus.ynarchive.com"
